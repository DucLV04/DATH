# Cấu hình kết nối PostgreSQL
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=DATH
DB_HOST=localhost
DB_PORT=5432

PORT=8080

JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_characters
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10

# Cấu hình gửi email (dùng Gmail)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password_16_chars  (Bật xác thực 2 lớp và tạo App Password để có pass)
# EMAIL_SECURE=false
# EMAIL_FROM="Your Name <your_email@gmail.com>"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=smtp_user
EMAIL_PASS=smtp_pass
EMAIL_SECURE=false
EMAIL_FROM="Dev <noreply@example.com>"

SERVER_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
