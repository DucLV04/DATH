# ==============================================
# Database Configuration
# ==============================================
DB_USER=postgres
DB_PASSWORD=12345678
DB_NAME=DATH
DB_HOST=localhost
DB_PORT=5432

# ==============================================
# Application Configuration
# ==============================================
PORT=8080
NODE_ENV=production

# ==============================================
# JWT Configuration
# ==============================================
JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_characters_for_security
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10

